# .env.example
# Create a copy of this file as .env.local and fill in your keys

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter (AI)
VITE_OPENROUTER_API_KEY=your-openrouter-key
VITE_AI_MODEL_TEXT=meta-llama/llama-3.3-70b-instruct:free
VITE_AI_MODEL_VISION=meta-llama/llama-3.2-11b-vision-instruct:free
